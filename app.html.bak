          <div>
            <label id="lbl-bk-prop">Объект</label>
            <select class="field" id="bk-prop" onchange="onBookPropSelect()"></select>
          </div>
          <div id="bk-room-row" style="display:none">
            <label id="lbl-bk-room">Комната</label>
            <select class="field" id="bk-room"><option value="">—</option></select>
