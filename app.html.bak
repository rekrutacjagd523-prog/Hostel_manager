            <label id="lbl-bk-status">Статус</label>
            <select class="field" id="bk-status">
              <option value="pending" id="opt-bk-pending">⏳ Ожидает</option>
              <option value="confirmed" id="opt-bk-confirmed">✓ Подтверждено</option>
              <option value="cancelled" id="opt-bk-cancelled">✕ Отменено</option>
              <option value="checkedIn" id="opt-bk-checkedin">🏠 Заселён</option>
            </select>
          </div>
        </div>
        <div>
          <label id="lbl-bk-notes">Заметки</label>
          <input class="field" id="bk-notes" placeholder="">
        </div>
        <div class="form-btns" style="margin-top:12px">
          <button class="btn btn-secondary" onclick="closeBookingForm()" id="btn-bk-cancel">Отмена</button>
          <button class="btn btn-primary" onclick="saveBooking()" id="btn-bk-save">Сохранить</button>
        </div>
      </div>
    </div>

  </div>

  <script type="module" src="js/main.js?v=4"></script>

    <!-- Onboarding Overlay -->
    <div class="overlay hidden" id="onboarding-overlay">
      <div class="modal" style="max-width:440px; text-align:center; padding: 40px 30px">
        <div style="margin-bottom:20px;display:flex;justify-content:center"><i data-lucide="rocket"
            style="width:56px;height:56px;color:var(--accent)"></i></div>
        <h2 style="margin-bottom:12px;font-size:24px" id="onb-title">Witaj w Lokum!</h2>
        <p style="color:var(--text2);font-size:15px;margin-bottom:32px;line-height:1.6">Rozpocznij w dwóch prostych krokach.</p>
        <div style="background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:20px;text-align:left;margin-bottom:24px">
          <div style="display:flex;align-items:center;margin-bottom:12px;gap:12px">
            <div style="width:28px;height:28px;border-radius:50%;background:var(--accent);color:#0d0d14;display:flex;align-items:center;justify-content:center;font-weight:bold">1</div>
            <div style="font-weight:600;font-size:15px">Stwórz obiekt</div>
          </div>
          <p style="color:var(--text3);font-size:13px;margin-bottom:16px;line-height:1.4">Dodaj pierwszy hostel, dom lub mieszkanie.</p>
          <button class="btn btn-primary" onclick="window.closeOnboarding(); openPropForm();"
            style="width:100%;justify-content:center;padding:10px"><i data-lucide="plus"
              style="width:16px;height:16px"></i> Dodaj obiekt</button>
        </div>
        <button class="btn btn-cancel" onclick="window.closeOnboarding()"
          style="background:transparent;border:none;color:var(--text3);font-size:13px">Pomiń konfigurację</button>
      </div>
    </div>

  </div>
  <script>
    window.closeOnboarding = function () {
      document.getElementById('onboarding-overlay').classList.add('hidden');
    };
    window._lucideRefresh = function() {
      if (window.lucide) window.lucide.createIcons();
    };

    // ── JS TOOLTIPS ──
    (function() {
      const box = document.createElement('div');
      box.className = 'tooltip-box';
      box.style.display = 'none';
      document.body.appendChild(box);

      let hideTimer;

      document.addEventListener('mouseover', function(e) {
        const el = e.target.closest('[data-tip]');
        if (!el) return;
        clearTimeout(hideTimer);
        const tip = el.getAttribute('data-tip');
        box.textContent = tip;
        // Show offscreen first to measure width
        box.style.left = '-9999px';
        box.style.top = '0';
        box.style.display = 'block';
        const bw = box.offsetWidth;
        const r = el.getBoundingClientRect();
        let left = r.left + r.width / 2 - bw / 2;
        left = Math.max(8, Math.min(left, window.innerWidth - bw - 8));
        const top = r.bottom + 8;
        box.style.left = left + 'px';
        box.style.top = top + 'px';
        requestAnimationFrame(() => box.classList.add('visible'));
      });

      document.addEventListener('mouseout', function(e) {
        const el = e.target.closest('[data-tip]');
        if (!el) return;
        box.classList.remove('visible');
        hideTimer = setTimeout(() => { box.style.display = 'none'; }, 200);
      });
    })();

    // ── FLATPICKR DATE PICKERS ──
    let _fpFrom = null, _fpTo = null;

    function initFlatpickr() {
      const lang = (window._settings && window._settings.lang) || 'PL';
      const locale = { PL: 'pl', UA: 'uk', RU: 'ru', EN: 'en', LT: 'en' }[lang] || 'pl';

      const common = {
        dateFormat: 'd.m.Y',
        locale: flatpickr.l10ns[locale] || flatpickr.l10ns.default,
        disableMobile: true,
        allowInput: false,
        appendTo: document.body,
      };

      if (_fpFrom) _fpFrom.destroy();
      if (_fpTo) _fpTo.destroy();

      _fpFrom = flatpickr('#period-from', {
        ...common,
        onChange(dates) {
          if (dates[0]) {
            const d = dates[0];
            // Write ISO format so report-export.js can parse it
            document.getElementById('period-from')._isoValue =
              d.getFullYear() + '-' + String(d.getMonth()+1).padStart(2,'0') + '-' + String(d.getDate()).padStart(2,'0');
            if (_fpTo) _fpTo.set('minDate', dates[0]);
          }
          if (window.refreshReport) window.refreshReport();
        }
      });

      _fpTo = flatpickr('#period-to', {
        ...common,
        onChange(dates) {
          if (dates[0]) {
            const d = dates[0];
            document.getElementById('period-to')._isoValue =
              d.getFullYear() + '-' + String(d.getMonth()+1).padStart(2,'0') + '-' + String(d.getDate()).padStart(2,'0');
            if (_fpFrom) _fpFrom.set('maxDate', dates[0]);
          }
          if (window.refreshReport) window.refreshReport();
        }
      });
    }

    window.openDatePicker = function(which) {
      if (!_fpFrom) initFlatpickr();
      if (which === 'from' && _fpFrom) _fpFrom.open();
      if (which === 'to' && _fpTo) _fpTo.open();
    };

    // Init flatpickr when custom period tab is clicked
    document.addEventListener('click', function(e) {
      if (e.target && e.target.id === 'pb-custom') {
        setTimeout(initFlatpickr, 80);
      }
    });

    // ── ONBOARDING TOUR ──
    window._tourActive = false;

    const TOUR_STEPS = [
      {
        target: 'btn-add', pos: 'bottom',
        titles: { PL:'Zamelduj mieszkańca', UA:'Заселіть мешканця', EN:'Check in a resident', RU:'Заселить жильца', LT:'Apgyvendinti gyventoją' },
        texts:  { PL:'Kliknij tutaj aby dodać pierwszego lokatora — imię, obiekt i miesięczna stawka.', UA:'Натисніть тут, щоб додати першого мешканця — імʼя, обʼєкт і місячна ставка.', EN:'Click to add your first resident — name, property and monthly rate.', RU:'Нажмите чтобы добавить первого жильца — имя, объект и ставка.', LT:'Spauskite pridėti pirmą gyventoją.' },
        preview: [
          { color:'#3b82f6', text:{ PL:'Imię i nazwisko', UA:'Імʼя та прізвище', EN:'Name', RU:'Имя', LT:'Vardas' } },
          { color:'#f5a623', text:{ PL:'Wybierz obiekt', UA:'Оберіть обʼєкт', EN:'Select property', RU:'Выберите объект', LT:'Pasirinkite objektą' } },
          { color:'#4cc98a', text:{ PL:'Stawka miesięczna', UA:'Місячна ставка', EN:'Monthly rate', RU:'Месячная ставка', LT:'Mėnesio mokestis' } },
        ],
      },
      {
        target: 'btn-add-prop', pos: 'bottom',
        titles: { PL:'Dodaj obiekt', UA:'Додайте обʼєкт', EN:'Add a property', RU:'Добавить объект', LT:'Pridėti objektą' },
        texts:  { PL:'Stwórz hostel, mieszkanie lub dom. System śledzi obłożenie automatycznie.', UA:'Створіть хостел, квартиру або будинок. Система автоматично відстежує завантаженість.', EN:'Create a hostel, apartment or house. The system tracks occupancy automatically.', RU:'Создайте хостел, квартиру или дом. Система отслеживает заполненность.', LT:'Sukurkite hostelį, butą ar namą.' },
        preview: [
          { color:'#8b5cf6', text:{ PL:'Hostel / Mieszkanie / Dom', UA:'Хостел / Квартира / Будинок', EN:'Hostel / Apartment / House', RU:'Хостел / Квартира / Дом', LT:'Hostelis / Butas / Namas' } },
          { color:'#f5a623', text:{ PL:'Adres i liczba miejsc', UA:'Адреса і кількість місць', EN:'Address and spots', RU:'Адрес и количество мест', LT:'Adresas ir vietų skaičius' } },
          { color:'#4cc98a', text:{ PL:'Wolne / Zajęte miejsca', UA:'Вільні / Зайняті місця', EN:'Free / Occupied spots', RU:'Свободные / Занятые места', LT:'Laisvos / Užimtos vietos' } },
        ],
      },
      {
        target: 'btn-report', pos: 'bottom',
        titles: { PL:'Generuj raporty', UA:'Генеруйте звіти', EN:'Generate reports', RU:'Создавать отчёты', LT:'Generuoti ataskaitas' },
        texts:  { PL:'Zestawienie finansowe za dowolny okres — eksport do PDF lub Excel jednym kliknięciem.', UA:'Фінансовий звіт за будь-який період — експорт у PDF або Excel одним кліком.', EN:'Financial summary for any period — export to PDF or Excel with one click.', RU:'Финансовый отчёт за любой период — экспорт в PDF или Excel.', LT:'Finansinė ataskaita už bet kokį laikotarpį.' },
        preview: [
          { color:'#f5a623', text:{ PL:'Tydzień / Miesiąc / Rok', UA:'Тиждень / Місяць / Рік', EN:'Week / Month / Year', RU:'Неделя / Месяц / Год', LT:'Savaitė / Mėnuo / Metai' } },
          { color:'#e05555', text:{ PL:'Export PDF', UA:'Експорт PDF', EN:'Export PDF', RU:'Экспорт PDF', LT:'Eksportuoti PDF' } },
          { color:'#4cc98a', text:{ PL:'Export Excel', UA:'Експорт Excel', EN:'Export Excel', RU:'Экспорт Excel', LT:'Eksportuoti Excel' } },
        ],
      },
      {
        target: 'theme-btn', pos: 'bottom',
        titles: { PL:'Motyw i ustawienia', UA:'Тема та налаштування', EN:'Theme & settings', RU:'Тема и настройки', LT:'Tema ir nustatymai' },
        texts:  { PL:'Tryb ciemny/jasny, język (PL/UA/EN/LT/RU) i waluta — dostosuj aplikację do swoich potrzeb.', UA:'Темний/світлий режим, мова (PL/UA/EN/LT/RU) і валюта — налаштуй застосунок під себе.', EN:'Dark/light mode, language (PL/UA/EN/LT/RU) and currency — customize the app to your needs.', RU:'Тёмная/светлая тема, язык и валюта — настройте приложение под себя.', LT:'Tamsi/šviesi tema, kalba ir valiuta.' },
        preview: [
          { color:'#a78bfa', text:{ PL:'🌙 Tryb ciemny / ☀️ jasny', UA:'🌙 Темний / ☀️ Світлий', EN:'🌙 Dark / ☀️ Light mode', RU:'🌙 Тёмная / ☀️ Светлая', LT:'🌙 Tamsi / ☀️ Šviesi' } },
          { color:'#f5a623', text:{ PL:'5 języków interfejsu', UA:'5 мов інтерфейсу', EN:'5 interface languages', RU:'5 языков интерфейса', LT:'5 kalbos' } },
          { color:'#4cc98a', text:{ PL:'PLN / EUR / USD', UA:'PLN / EUR / USD', EN:'PLN / EUR / USD', RU:'PLN / EUR / USD', LT:'PLN / EUR / USD' } },
        ],
      },
    ];

    window.startTour = function() {
      if (window._tourActive) return;
      window._tourActive = true;
      let step = 0;

      const overlay = document.createElement('div');
      overlay.className = 'tour-overlay';
      overlay.id = 'tour-overlay';

      const spotlight = document.createElement('div');
      spotlight.className = 'tour-spotlight';

      const bubble = document.createElement('div');
      bubble.className = 'tour-bubble';

      overlay.appendChild(spotlight);
      document.body.appendChild(overlay);
      document.body.appendChild(bubble);

      function getLang() { return (window._settings && window._settings.lang) || 'EN'; }

      function showStep(i) {
        const s = TOUR_STEPS[i];
        const targetEl = document.getElementById(s.target);
        const lang = getLang();

        // Spotlight
        if (targetEl) {
          const r = targetEl.getBoundingClientRect();
          const pad = 8;
          spotlight.style.left   = (r.left - pad + window.scrollX) + 'px';
          spotlight.style.top    = (r.top  - pad + window.scrollY) + 'px';
          spotlight.style.width  = (r.width  + pad*2) + 'px';
          spotlight.style.height = (r.height + pad*2) + 'px';
        }

        // Bubble content
        const dots = TOUR_STEPS.map((_, di) =>
          `<div class="tour-dot${di===i?' active':''}"></div>`).join('');

        const previewHtml = s.preview ? `
          <div class="tour-preview">
            ${s.preview.map(p => `<div class="tour-preview-row"><div class="tour-preview-dot" style="background:${p.color}"></div><span>${p.text[lang]||p.text.EN}</span></div>`).join('')}
          </div>` : '';

        bubble.innerHTML = `
          <div class="tour-step">Krok ${i+1} / ${TOUR_STEPS.length}</div>
          <div class="tour-title">${s.titles[lang]||s.titles.EN}</div>
          <div class="tour-text">${s.texts[lang]||s.texts.EN}</div>
          ${previewHtml}
          <div class="tour-btns">
            <span class="tour-skip" onclick="endTour()">Pomiń</span>
            <div class="tour-dots">${dots}</div>
            ${i>0?`<button class="tour-prev" onclick="tourGo(${i-1})">←</button>`:''}
            <button class="tour-next" onclick="${i<TOUR_STEPS.length-1?'tourGo('+(i+1)+')':'endTour()'}">
              ${i<TOUR_STEPS.length-1?'Dalej →':'Gotowe ✓'}
            </button>
          </div>`;

        // Position bubble near target
        if (targetEl) {
          const r = targetEl.getBoundingClientRect();
          let top = r.bottom + 14;
          let left = r.left + r.width/2 - 140;
          // Keep in viewport
          left = Math.max(12, Math.min(left, window.innerWidth - 292));
          if (top + 160 > window.innerHeight) top = r.top - 180;
          bubble.style.top  = top + 'px';
          bubble.style.left = left + 'px';
        }
      }

      window.tourGo = function(i) {
        step = i;
        showStep(step);
      };

      window.endTour = function() {
        window._tourActive = false;
        overlay.remove();
        bubble.remove();
        localStorage.setItem('lokum-tour-done', '1');
      };

      showStep(0);
    };

    // Auto-start tour for new users on first login
    window.addEventListener('load', function() {
      if (localStorage.getItem('lokum-tour-done')) return;

      // Wait for Firebase auth + data to load
      let attempts = 0;
      const checkReady = setInterval(function() {
        attempts++;
        const app = document.getElementById('main-app');
        const isVisible = app && app.style.display !== 'none';
        const dataLoaded = window._resLoaded && window._propsLoaded;

        if (isVisible && dataLoaded) {
          clearInterval(checkReady);
          const hasData = (window._residents && window._residents.length > 0) ||
                          (window._properties && window._properties.length > 0);
          if (!hasData) {
            // New user — show welcome modal then start tour
            setTimeout(function() { startTour(); }, 800);
          }
        }
        if (attempts > 30) clearInterval(checkReady); // stop after 15s
      }, 500);
    });

    // Show tour button always (for returning users)
    window.onUserLoggedIn = (function(original) {
      return function(user) {
        if (original) original(user);
        const btn = document.getElementById('tour-btn');
        if (btn) btn.style.display = 'inline-flex';
      };
    })(window.onUserLoggedIn);

  </script>
  <script type="module" src="js/main.js?v=4"></script>
</body>

</html>