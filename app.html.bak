    </div>

    <!-- Booking Form -->
    <div class="overlay hidden" id="booking-overlay">
      <div class="modal" style="max-width:460px">
        <h3 id="booking-form-title">📅 Новая бронь</h3>
        <input type="hidden" id="bk-edit-id">
